# 前端部署配置（复制为 FusionCareer-View 根目录 .env.frontend，勿提交 Git）
# cp deploy/env.frontend.example .env.frontend

# ── Mac HTTP 供 Python 机 curl（默认 8766，避免与 Backend Java 包 8765 冲突）──
FRONTEND_HTTP_PORT=8766

# ── Python 机静态资源目录（须与 Nginx 挂载一致）──
PYTHON_DIST_DIR=/home/vmadmin/fusioncareer/frontend/dist

# ── 可选：Mac 上直接 rsync（需本机能 SSH 到 Python 机）──
PYTHON_HOST=10.107.13.184
PYTHON_USER=vmadmin
# PYTHON_SSH_OPTS=-o StrictHostKeyChecking=no

# ── 可选：部署后重建网关 Nginx（compose 在 FusionCareer-Backend/deploy）──
# PYTHON_DEPLOY_DIR=/home/vmadmin/fusioncareer/FusionCareer-Backend/deploy
# GATEWAY_PROJECT=fc-gateway
# GATEWAY_COMPOSE_FILE=docker-compose.gateway.host.yml
